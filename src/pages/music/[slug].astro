---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const releases = await getCollection('releases');
  return releases.map((release) => ({
    params: { slug: release.id },
    props: { release },
  }));
}

const { release } = Astro.props;
const { title, datePublished, cover, primaryUrl, series } = release.data;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
const coverSrc = base + cover.replace(/^\//, '');
const primaryPlatform = primaryUrl.includes('spotify') ? 'Spotify' : 'Deezer';
---
<Base
  title={`${title} — Chris Gwim`}
  description={`${title} by Chris Gwim — released ${datePublished}. Listen on ${primaryPlatform}, SoundCloud, and all major platforms.`}
>
  <article class="release">
    <div class="release-cover-frame">
      <div class="release-cover-label">
        <span>RELEASE — {datePublished}</span>
        {series && <span class="series-tag">SERIES: {series.toUpperCase()}</span>}
      </div>
      <img class="release-cover" src={coverSrc} alt={`${title} cover art`} width="500" height="500" />
    </div>

    <div class="release-meta">
      <h1 class="release-title">{title}</h1>
      <table class="meta-table">
        <tbody>
          <tr><td>RELEASED</td><td>{datePublished}</td></tr>
          <tr><td>ARTIST</td><td>Chris Gwim</td></tr>
          {series && <tr><td>SERIES</td><td>{series}</td></tr>}
        </tbody>
      </table>
      <div class="release-links">
        <a class="jack" href={primaryUrl} target="_blank" rel="noopener">
          <span class="jack-dot" aria-hidden="true"></span>
          <span>Listen on {primaryPlatform} ↗</span>
        </a>
        <a class="jack" href="https://soundcloud.com/chrisgwim" target="_blank" rel="noopener">
          <span class="jack-dot" aria-hidden="true"></span>
          <span>SoundCloud ↗</span>
        </a>
      </div>
      <a class="back-link" href={`${base}music/`}>← back to track list</a>
    </div>
  </article>
</Base>

<style>
  .release {
    display: grid;
    grid-template-columns: minmax(0, 480px) 1fr;
    gap: 28px;
    padding: 40px 0 28px;
    align-items: start;
  }
  @media (max-width: 700px) {
    .release { grid-template-columns: 1fr; }
  }
  .release-cover-frame {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 4px;
    overflow: hidden;
  }
  .release-cover-label {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    padding: 9px 14px;
    border-bottom: 1px solid var(--line);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dimmer);
  }
  .series-tag { color: var(--amber); }
  .release-cover {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }
  @media (prefers-reduced-motion: no-preference) {
    .release-cover { animation: reveal 0.6s ease-out; }
  }
  @keyframes reveal {
    from { opacity: 0; transform: scale(0.985); }
    to { opacity: 1; transform: scale(1); }
  }
  .release-title {
    font-family: var(--display);
    font-weight: 800;
    font-stretch: condensed;
    font-size: clamp(24px, 4vw, 34px);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin: 0 0 18px;
    line-height: 1;
  }
  .meta-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--mono);
    font-size: 11px;
    margin: 0 0 20px;
  }
  .meta-table td {
    padding: 7px 0;
    border-bottom: 1px solid var(--line-faint);
  }
  .meta-table td:first-child {
    color: var(--text-dimmer);
    letter-spacing: 0.08em;
    width: 96px;
  }
  .meta-table td:last-child { color: var(--text); }
  .release-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 0 0 20px;
  }
  .jack {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: 3px;
    background: var(--panel);
    text-decoration: none;
    color: var(--text);
    font-size: 12px;
  }
  .jack-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--line);
    flex-shrink: 0;
  }
  .jack:hover .jack-dot,
  .jack:focus-visible .jack-dot { background: var(--amber); }
  .back-link {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dimmer);
    text-decoration: none;
  }
  .back-link:hover { color: var(--text-dim); }
</style>

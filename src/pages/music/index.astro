---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const releases = (await getCollection('releases')).sort(
  (a, b) => b.data.datePublished.localeCompare(a.data.datePublished)
);
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
---
<Base
  title="Track List — Chris Gwim"
  description="Full Chris Gwim catalog — every release with cover art, dates, and streaming links."
>
  <section class="section catalog" aria-labelledby="catalog-h">
    <div class="section-head">
      <h1 class="section-title" id="catalog-h">Track list</h1>
      <span class="section-count">{String(releases.length).padStart(2, '0')} releases</span>
    </div>
    <div class="tracklist">
      {releases.map((release, i) => (
        <a class="track-row" href={`${base}music/${release.id}/`}>
          <span class="track-num">{String(i + 1).padStart(2, '0')}</span>
          <img
            class="track-cover"
            src={base + release.data.cover.replace(/^\//, '')}
            alt={`${release.data.title} cover`}
            width="44"
            height="44"
            loading="lazy"
          />
          <span class="track-title">
            {release.data.title}
            {i === 0 && <span class="track-latest">NEW</span>}
            {release.data.series && <span class="track-series">{release.data.series.toUpperCase()}</span>}
          </span>
          <span class="track-date">{release.data.datePublished}</span>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .catalog { padding-top: 40px; }
  .section-title { font-size: clamp(20px, 3vw, 26px); }
  .tracklist { display: flex; flex-direction: column; }
  .track-row {
    display: grid;
    grid-template-columns: 28px 44px 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 8px;
    border-bottom: 1px solid var(--line-faint);
    text-decoration: none;
    color: inherit;
  }
  .track-row:last-child { border-bottom: none; }
  .track-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dimmer);
    font-variant-numeric: tabular-nums;
  }
  .track-cover {
    display: block;
    border-radius: 2px;
    border: 1px solid var(--line-faint);
  }
  .track-title { font-size: 14px; color: var(--text); }
  .track-latest {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--amber);
    border: 1px solid var(--amber-dim);
    border-radius: 2px;
    padding: 1px 5px;
    margin-left: 8px;
    letter-spacing: 0.06em;
    vertical-align: 1px;
  }
  .track-series {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--text-dimmer);
    border: 1px solid var(--line);
    border-radius: 2px;
    padding: 1px 5px;
    margin-left: 8px;
    letter-spacing: 0.06em;
    vertical-align: 1px;
  }
  .track-date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dimmer);
    font-variant-numeric: tabular-nums;
  }
  @media (max-width: 480px) {
    .track-date { display: none; }
  }
  .track-row:hover .track-title,
  .track-row:focus-visible .track-title { color: var(--amber); }
</style>

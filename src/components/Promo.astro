---
const referralUrl = 'https://invite.soundcloud.com/magnusnova!8bf953f927!a';
---
<div class="promo">
  <div class="promo-label">
    <span>AUX — SUPPORT THE MUSIC</span>
  </div>
  <div class="promo-body">
    <p class="promo-copy">Get a free month of SoundCloud Artist Pro on me.</p>
    <a class="promo-link" href={referralUrl} target="_blank" rel="noopener">
      Claim your free month ↗
    </a>
  </div>
</div>

<style>
  .promo {
    margin: 0 0 28px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 4px;
  }
  .promo-label {
    padding: 9px 14px;
    border-bottom: 1px solid var(--line);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dimmer);
  }
  .promo-body {
    padding: 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
  }
  .promo-copy {
    margin: 0;
    font-size: 14px;
    color: var(--text-dim);
  }
  .promo-link {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--amber);
    text-decoration: none;
    border: 1px solid var(--amber-dim);
    border-radius: 3px;
    padding: 8px 14px;
    white-space: nowrap;
  }
  .promo-link:hover,
  .promo-link:focus-visible {
    background: rgba(226, 163, 63, 0.08);
    border-color: var(--amber);
  }
</style>

---
import { getCollection } from 'astro:content';

const releases = (await getCollection('releases')).sort(
  (a, b) => b.data.datePublished.localeCompare(a.data.datePublished)
);
---
<section class="section" aria-labelledby="tracklist-h">
  <div class="section-head">
    <h2 class="section-title" id="tracklist-h">Track list</h2>
    <span class="section-count">{String(releases.length).padStart(2, '0')} releases</span>
  </div>
  <div class="tracklist">
    {releases.map((release, i) => (
      <a class="track-row" href={release.data.primaryUrl} target="_blank" rel="noopener">
        <span class="track-num">{String(i + 1).padStart(2, '0')}</span>
        <span class="track-title">
          {release.data.title}
          {i === 0 && <span class="track-latest">NEW</span>}
        </span>
        <span class="track-link">open ↗</span>
      </a>
    ))}
  </div>
</section>

<style>
  .tracklist { display: flex; flex-direction: column; }
  .track-row {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 10px 8px;
    border-bottom: 1px solid var(--line-faint);
    text-decoration: none;
    color: inherit;
  }
  .track-row:last-child { border-bottom: none; }
  .track-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dimmer);
    font-variant-numeric: tabular-nums;
  }
  .track-title { font-size: 14px; color: var(--text); }
  .track-latest {
    font-family: var(--mono);
    font-size: 9px;
    color: var(--amber);
    border: 1px solid var(--amber-dim);
    border-radius: 2px;
    padding: 1px 5px;
    margin-left: 8px;
    letter-spacing: 0.06em;
    vertical-align: 1px;
  }
  .track-link {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dimmer);
  }
  .track-row:hover .track-title,
  .track-row:focus-visible .track-title { color: var(--amber); }
  .track-row:hover .track-link,
  .track-row:focus-visible .track-link { color: var(--text-dim); }
</style>
